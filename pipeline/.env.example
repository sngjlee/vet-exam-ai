# pipeline/.env.example — 템플릿. 실제 사용 시 이 파일을 복사해서 pipeline/.env 로 저장
# ⚠️ 이 파일(.env.example)은 git에 커밋됩니다. 절대 실제 키를 여기 넣지 마세요.
# 실제 키는 pipeline/.env 에만 (gitignore 처리되어 안전합니다)

# Claude API 키 (rewrite.py에서 사용)
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (upload.py에서 사용 — 아직 미작성)
SUPABASE_URL=https://xxx.supabase.co
# anon key 아닌 service_role key
SUPABASE_SERVICE_KEY=eyJ...
